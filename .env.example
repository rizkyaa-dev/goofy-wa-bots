NODE_ENV=development
DATABASE_URL="file:./dev.db"

# Session files for whatsapp-web.js LocalAuth.
WHATSAPP_CLIENT_ID=personal
WHATSAPP_DATA_PATH=.wwebjs_auth
WHATSAPP_HEADLESS=true
# Optional. Isi kalau install dependency di-skip download Chromium.
# Contoh Windows Chrome:
# WHATSAPP_BROWSER_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
WHATSAPP_BROWSER_PATH=
WHATSAPP_TYPING_ENABLED=true
WHATSAPP_TYPING_MIN_MS=900
WHATSAPP_TYPING_MAX_MS=6500
WHATSAPP_TYPING_CHARS_PER_SECOND=22

# Use WhatsApp JIDs, for example: 6281234567890@c.us
# If BOT_ALLOWED_NUMBERS is empty, BOT_OWNER_NUMBER is used as the only allowlist entry.
# If both are empty, all incoming chats are allowed.
BOT_OWNER_NUMBER=
BOT_ALLOWED_NUMBERS=
BOT_DEFAULT_MODE=command_only

# Temporary broad responder. If true, any incoming chat that says exactly "hai"
# will receive "iya ada yg bisa saya bantu." before allowlist checks.
TEMP_HAI_REPLY_ENABLED=true

# LLM provider defaults. Supported providers: gemini, openai, deepseek.
LLM_PROVIDER=gemini
LLM_MAX_TOKENS=1200

GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_MODEL=gemini-3.5-flash
GEMINI_TEMPERATURE=
GEMINI_TOP_P=
GEMINI_MAX_TOKENS=

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.5
OPENAI_TEMPERATURE=
OPENAI_TOP_P=
OPENAI_MAX_TOKENS=
OPENAI_REASONING_EFFORT=high

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_TEMPERATURE=
DEEPSEEK_TOP_P=
DEEPSEEK_MAX_TOKENS=
DEEPSEEK_REASONING_EFFORT=
DEEPSEEK_THINKING_TYPE=enabled

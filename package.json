{
  "name": "bot-wa",
  "version": "0.1.0",
  "private": true,
  "description": "Personal WhatsApp chatbot using whatsapp-web.js with an expandable modular architecture.",
  "license": "SEE LICENSE IN LICENSE",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only --ignore-watch .wwebjs_auth --ignore-watch .wwebjs_cache --ignore-watch prisma src/main.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "db:reset": "node scripts/ensure-sqlite-db.js && prisma db push --force-reset",
    "prisma:studio": "prisma studio",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.7.0",
    "@nestjs/common": "^11.1.3",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.3",
    "@nestjs/platform-express": "^11.1.3",
    "@prisma/client": "^6.9.0",
    "pino": "^9.7.0",
    "qrcode-terminal": "^0.12.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "whatsapp-web.js": "^1.27.0",
    "zod": "^3.25.56"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/qrcode-terminal": "^0.12.2",
    "prisma": "^6.9.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3"
  }
}

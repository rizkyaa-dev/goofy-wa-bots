generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum BotMode {
  command_only
  auto_reply
  silent
}

enum MessageDirection {
  inbound
  outbound
}

model ContactSetting {
  id        String   @id @default(cuid())
  chatId    String   @unique
  mode      BotMode  @default(command_only)
  persona   String?
  llmProvider String?
  llmModel    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notes Note[]
}

model ConversationMessage {
  id           String           @id @default(cuid())
  messageId    String?          @unique
  chatId       String
  authorId     String?
  direction    MessageDirection
  body         String
  responseText String?
  createdAt    DateTime         @default(now())
}

model Note {
  id        String         @id @default(cuid())
  chatId    String
  text      String
  createdAt DateTime       @default(now())

  contactSetting ContactSetting @relation(fields: [chatId], references: [chatId], onDelete: Cascade)

  @@index([chatId, createdAt])
}

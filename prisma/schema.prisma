generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum BotMode {
  command_only
  auto_reply
  silent
}

enum MessageDirection {
  inbound
  outbound
}

enum RoleplayMemoryKind {
  user_fact
  relationship
  episode
  preference
  boundary
  goal
}

enum RoleplayMood {
  neutral
  happy
  sad
  annoyed
  warm
  playful
  sleepy
  excited
  jealous
  worried
  swing
  sensual
  flirty
  aroused
  needy
}

model ContactSetting {
  id        String   @id @default(cuid())
  chatId    String   @unique
  mode      BotMode  @default(command_only)
  persona   String?
  llmProvider String?
  llmModel    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notes Note[]

  roleplayState RoleplayState?
  roleplayPresenceState RoleplayPresenceState?
  roleplayMemories RoleplayMemory[]
}

model ConversationMessage {
  id           String           @id @default(cuid())
  messageId    String?          @unique
  chatId       String
  authorId     String?
  direction    MessageDirection
  body         String
  responseText String?
  createdAt    DateTime         @default(now())
}

model Note {
  id        String         @id @default(cuid())
  chatId    String
  text      String
  createdAt DateTime       @default(now())

  contactSetting ContactSetting @relation(fields: [chatId], references: [chatId], onDelete: Cascade)

  @@index([chatId, createdAt])
}

model RoleplayState {
  id                String       @id @default(cuid())
  chatId            String       @unique
  mood              RoleplayMood @default(neutral)
  affection         Int          @default(50)
  trust             Int          @default(50)
  energy            Int          @default(70)
  tension           Int          @default(0)
  intimacy          Int          @default(10)
  shyness           Int          @default(15)
  curiosity         Int          @default(55)
  volatility        Int          @default(15)
  desire            Int          @default(20)
  inhibition        Int          @default(55)
  comfort           Int          @default(55)
  compliance        Int          @default(40)
  summary           String?
  lastInteractionAt DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  contactSetting ContactSetting @relation(fields: [chatId], references: [chatId], onDelete: Cascade)
}

model RoleplayMemory {
  id         String             @id @default(cuid())
  chatId     String
  kind       RoleplayMemoryKind
  content    String
  importance Int                @default(50)
  confidence Float              @default(1.0)
  sourceText String?
  expiresAt  DateTime?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  contactSetting ContactSetting @relation(fields: [chatId], references: [chatId], onDelete: Cascade)

  @@index([chatId, importance, updatedAt])
  @@index([chatId, kind, updatedAt])
}

model RoleplayPresenceState {
  id               String   @id @default(cuid())
  chatId           String   @unique
  activityType     String
  statusText       String
  locationLabel    String
  socialContext    String
  interruptibility String
  source           String
  priority         Int      @default(10)
  startedAt        DateTime @default(now())
  expiresAt        DateTime
  lastReason       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  contactSetting ContactSetting @relation(fields: [chatId], references: [chatId], onDelete: Cascade)
}

model ProactiveLog {
  id          String   @id @default(cuid())
  chatId      String
  triggerType String   // 'morning_greeting', 'night_greeting', 'inactivity'
  sentAt      DateTime @default(now())

  @@index([chatId, triggerType, sentAt])
}

